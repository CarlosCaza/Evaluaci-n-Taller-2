# Funciones auxiliares
def get_random_user_agent() -> str:
    """Devuelve un User-Agent aleatorio de la lista."""
    return random.choice(USER_AGENTS)

def get_headers() -> Dict[str, str]:
    """Construye headers con User-Agent rotativo."""
    return {
        'User-Agent': get_random_user_agent(),
        'Accept': 'application/rss+xml, application/xml, text/xml, */*',
        'Accept-Language': 'es-ES,es;q=0.9,en;q=0.8',
        'Connection': 'keep-alive',
    }

def check_robots_txt(source_name: str, base_url: str) -> bool:
    """
    Verifica si robots.txt permite el scraping de la fuente.
    Esta es una implementación simplificada. En un entorno real,
    se usaría la librería 'robotparser' de Python.
    """
    try:
        robots_url = f"{base_url}/robots.txt"
        print(f"  Verificando robots.txt: {robots_url}")
        response = requests.get(robots_url, headers=get_headers(), timeout=5)
        if response.status_code == 200:
            content = response.text.lower()
            # Verificar si hay reglas que bloqueen /rss o /news
            if 'disallow: /rss' in content or 'disallow: /news' in content:
                print(f"  ⚠️  robots.txt de {source_name} parece restringir el acceso.")
                return False
            else:
                print(f"  ✅ robots.txt de {source_name} es permisivo.")
                return True
        else:
            # Si no hay robots.txt, asumimos permisivo (por defecto)
            print(f"  ℹ️  No se encontró robots.txt en {source_name}. Se asume permisivo.")
            return True
    except Exception as e:
        print(f"  ⚠️  Error al verificar robots.txt de {source_name}: {e}")
        print(f"  ℹ️  Se continúa con la extracción (asumiendo permisivo).")
        return True
