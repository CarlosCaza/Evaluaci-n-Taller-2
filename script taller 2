import requests
import xml.etree.ElementTree as ET
from bs4 import BeautifulSoup
import csv
import time
import re
from datetime import datetime

RSS_FEEDS = {
    'WHO News': 'https://www.who.int/rss-feeds/news-english.xml',
    'BBC News': 'http://feeds.bbci.co.uk/news/health/rss.xml'
}

OUTPUT_CSV = 'vacunas_analisis.csv'
USER_AGENT = 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'

def clean(text):
    return re.sub(r'\s+', ' ', text).strip() if text else ''

def get_date(text):
    if not text:
        return 'Fecha no disponible'
    try:
        return datetime.strptime(text, '%a, %d %b %Y %H:%M:%S %Z').strftime('%Y-%m-%d')
    except:
        try:
            return datetime.strptime(text.replace('Z', '+00:00'), '%Y-%m-%dT%H:%M:%S%z').strftime('%Y-%m-%d')
        except:
            return text

def analyze(title, content):
    combined = (title + ' ' + content).lower()

    desinfo = {
        'autismo': 'autism' in combined or 'autista' in combined,
        'microchip': 'microchip' in combined or 'chip' in combined,
        'conspiracion': 'conspiracy' in combined or 'conspiración' in combined
    }

    confiable = {
        'evidencia': any(w in combined for w in ['study', 'research', 'evidence', 'ensayo', 'clinical']),
        'advertencia': any(w in combined for w in ['side effect', 'risk', 'advertencia', 'efecto secundario'])
    }

    score = sum([3 if desinfo['autismo'] else 0,
                 3 if desinfo['microchip'] else 0,
                 2 if desinfo['conspiracion'] else 0])
    score -= sum([1 if confiable['evidencia'] else 0,
                  1 if confiable['advertencia'] else 0])
    score = max(0, min(10, score))

    return {
        'autismo': 'Si' if desinfo['autismo'] else 'No',
        'microchip': 'Si' if desinfo['microchip'] else 'No',
        'conspiracion': 'Si' if desinfo['conspiracion'] else 'No',
        'evidencia': 'Si' if confiable['evidencia'] else 'No',
        'advertencia': 'Si' if confiable['advertencia'] else 'No',
        'score': score
    }

def get_content(url):
    if not url:
        return ''
    time.sleep(1)
    try:
        resp = requests.get(url, headers={'User-Agent': USER_AGENT}, timeout=15)
        soup = BeautifulSoup(resp.content, 'html.parser')
        body = soup.find('article') or soup.find('main') or soup.find('div', class_=re.compile('content|body|story'))
        if not body:
            body = soup
        paragraphs = body.find_all('p')
        content = ' '.join([clean(p.text) for p in paragraphs if len(p.text) > 30])
        return content[:1000]
    except:
        return ''

def fetch_rss(url, source):
    print(f"\nExtrayendo {source}: {url}")
    try:
        resp = requests.get(url, headers={'User-Agent': USER_AGENT}, timeout=15)
        root = ET.fromstring(resp.content)
        items = root.findall('.//item') or root.findall('.//entry')

        articles = []
        for item in items[:8]:
            title = clean(item.find('title').text if item.find('title') is not None else '')
            link = (item.find('link').text or '') if item.find('link') is not None else ''
            date = get_date(item.find('pubDate').text if item.find('pubDate') is not None else '')

            content = get_content(link)
            analysis = analyze(title, content)

            articles.append({
                'fuente': source,
                'titulo': title,
                'fecha': date,
                'enlace': link,
                'resumen': content[:300] + '...' if len(content) > 300 else content,
                **analysis
            })

        print(f"   Extraidos {len(articles)} articulos")
        return articles
    except Exception as e:
        print(f"   Error: {e}")
        return []

def main():
    print("SISTEMA DE ANALISIS DE DESINFORMACION SOBRE VACUNAS")
    print("WHO News vs BBC News")

    all_articles = []
    for name, url in RSS_FEEDS.items():
        all_articles.extend(fetch_rss(url, name))

    if not all_articles:
        print("\nNo se extrajeron articulos.")
        return

    fieldnames = ['fuente', 'titulo', 'fecha', 'enlace', 'resumen',
                  'autismo', 'microchip', 'conspiracion', 'evidencia', 'advertencia', 'score']

    with open(OUTPUT_CSV, 'w', newline='', encoding='utf-8') as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows(all_articles)

    print(f"\nDatos guardados en: {OUTPUT_CSV}")
    print(f"Total: {len(all_articles)} articulos")

    print("RESUMEN POR FUENTE")
    
    for source in set(a['fuente'] for a in all_articles):
        sub = [a for a in all_articles if a['fuente'] == source]
        avg_score = sum(a['score'] for a in sub) / len(sub)
        print(f"\n{source}:")
        print(f"   Articulos: {len(sub)}")
        print(f"   Score desinformacion: {avg_score:.1f}/10")
        print(f"   Evidencia cientifica: {sum(1 for a in sub if a['evidencia'] == 'Si')}/{len(sub)}")
        print(f"   Advertencias: {sum(1 for a in sub if a['advertencia'] == 'Si')}/{len(sub)}")

if __name__ == "__main__":
    main()
